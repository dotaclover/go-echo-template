# Database
DB_TYPE=sqlite
SQLITE_PATH=./data/app.db
# DB_TYPE=mysql
# MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/myapp?charset=utf8mb4&parseTime=True&loc=Local
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=myapp

# JWT
JWT_SECRET=change-me-to-a-secure-secret-key-at-least-32-chars
JWT_EXPIRATION=168h
JWT_REFRESH_EXPIRATION=336h

# App
APP_NAME=MyApp
APP_VERSION=0.1.0
APP_ENV=development
APP_HOST=localhost
APP_PORT=8080
APP_DEBUG=true
APP_READ_TIMEOUT=15s
APP_WRITE_TIMEOUT=15s
APP_IDLE_TIMEOUT=60s
APP_SHUTDOWN_TIMEOUT=30s

# Rate Limit
RATE_LIMIT_ENABLED=false
RATE_LIMIT_LIMIT=120
RATE_LIMIT_WINDOW=1m

# Log
LOG_LEVEL=info
LOG_FORMAT=text
LOG_OUTPUT=both
LOG_FILE=./logs/app.log
